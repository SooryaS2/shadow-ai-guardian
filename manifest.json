{
  "manifest_version": 3,
  "name": "Shadow AI Guardian",
  "version": "1.0",
  "description": "Detects unauthorized AI tool usage, nudges employees towards safe alternatives, and logs risk metadata.",
  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Shadow AI Guardian",
    "default_popup": "dashboard.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "styles.css",
        "admin.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}